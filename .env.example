NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
SUPABASE_SERVICE_KEY=

# Canonical app URL for emails (production domain, no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ZeptoMail — use HTTP API token (NOT the SMTP password in client-side code)
# Dashboard → SMTP/API → copy "Password" token into ZEPTOMAIL_API_KEY
# Rotate immediately if exposed in chat or commits
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_EMAIL=noreply@yourdomain.com
ZEPTOMAIL_FROM_NAME=RNReady

# Protect cron routes (Vercel Cron sends Authorization: Bearer CRON_SECRET)
CRON_SECRET=
